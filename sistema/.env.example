# Chave da API DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# ID da instituicao usada por padrao para clientes novos
INSTITUICAO_PADRAO_ID=1

# Modelo da DeepSeek. Recomendado: deepseek-v4-flash (rapido e barato).
# O nome antigo "deepseek-chat" foi descontinuado pela DeepSeek em 24/07/2026.
# Alternativa: deepseek-v4-pro (mais caro, casos dificeis).
DEEPSEEK_MODEL=deepseek-v4-flash

# (Opcional) Chave da API do Google Gemini (https://aistudio.google.com/api-keys).
# Com ela o bot transcreve audios e descreve imagens enviados pelos clientes,
# e responde normalmente. Sem ela, midia vai para atendimento humano (aviso).
# Tambem pode ser colada pelo painel, na aba "Chave da API".
GEMINI_API_KEY=

# Modelo do Gemini usado para audio/imagem. Padrao: gemini-flash-lite-latest
# (alias do flash-lite estavel mais recente, o mais barato — nao quebra quando
# o Google aposenta uma versao). Alternativa: gemini-flash-latest.
GEMINI_MODEL=gemini-flash-lite-latest

# Tamanho maximo (MB) de audio/imagem enviado para transcricao/descricao.
# Acima disso a midia cai no aviso de atendimento humano. Padrao: 15.
MIDIA_MAX_MB=15

# Quantas mensagens recentes o bot envia ao modelo como contexto imediato
# (e mantem no banco por cliente). Padrao: 30 (~15 trocas). O contexto anterior
# a essa janela e preservado no resumo .md de cada cliente.
HISTORICO_LIMIT=30

# Tempo de espera (ms) apos a ultima mensagem antes de responder. Agrupa
# mensagens enviadas em sequencia em uma unica resposta. Padrao: 5000 (5s).
DEBOUNCE_MS=5000

# Intervalo minimo (ms) entre avisos de midia (audio/imagem) para um mesmo
# numero, para nao repetir o alerta numa rajada de midias. Padrao: 60000 (60s).
MIDIA_COOLDOWN_MS=60000

# (Opcional) Endpoint de consulta de processos do escritorio.
# Se vazio, usa o padrao embutido no codigo.
DATAJUD_API_URL=https://ferreiraramos.adv.br/api/datajud_autocomplete.php
