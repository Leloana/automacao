# === WhatsApp oficial (Cloud API da Meta) ===
# Token de acesso permanente (Usuario do sistema no Meta Business — NAO o token
# temporario de 24h da tela inicial). Tambem pode ser colado pelo painel.
WHATSAPP_TOKEN=
# ID do numero (Phone Number ID), do painel da Meta (nao e o telefone). Painel: aba Chave da API.
WHATSAPP_PHONE_NUMBER_ID=
# String secreta escolhida por voce; a mesma configurada no webhook do painel da Meta.
WHATSAPP_VERIFY_TOKEN=
# Segredo do app (Meta) para validar a assinatura do webhook (X-Hub-Signature-256).
# Sem ele o webhook funciona, mas a assinatura NAO e validada (aviso no boot).
WHATSAPP_APP_SECRET=
# Versao da Graph API. A Meta descontinua versoes antigas periodicamente.
GRAPH_API_VERSION=v21.0

# === Telegram (aviso ao advogado) ===
# Token do bot criado com o @BotFather. Necessario para avisar o advogado nos
# encaminhamentos (o WhatsApp oficial exigiria template aprovado). Painel: aba Chave da API.
TELEGRAM_BOT_TOKEN=
# (Opcional) chat_id de destino padrao, usado quando o advogado escolhido nao tem
# telegram_chat_id proprio em advogados.json (ex.: id de um grupo do escritorio).
TELEGRAM_CHAT_ID_PADRAO=

# Chave da API DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# ID da instituicao usada por padrao para clientes novos
INSTITUICAO_PADRAO_ID=1

# Modelo da DeepSeek. Recomendado: deepseek-v4-flash (rapido e barato).
# O nome antigo "deepseek-chat" foi descontinuado pela DeepSeek em 24/07/2026.
# Alternativa: deepseek-v4-pro (mais caro, casos dificeis).
DEEPSEEK_MODEL=deepseek-v4-flash

# (Opcional) Chave da API do Google Gemini (https://aistudio.google.com/api-keys).
# Com ela o bot transcreve audios e descreve imagens enviados pelos clientes,
# e responde normalmente. Sem ela, midia vai para atendimento humano (aviso).
# Tambem pode ser colada pelo painel, na aba "Chave da API".
GEMINI_API_KEY=

# Modelo do Gemini usado para audio/imagem. Padrao: gemini-flash-lite-latest
# (alias do flash-lite estavel mais recente, o mais barato — nao quebra quando
# o Google aposenta uma versao). Alternativa: gemini-flash-latest.
GEMINI_MODEL=gemini-flash-lite-latest

# Tamanho maximo (MB) de audio/imagem enviado para transcricao/descricao.
# Acima disso a midia cai no aviso de atendimento humano. Padrao: 15.
MIDIA_MAX_MB=15

# Quantas mensagens recentes o bot envia ao modelo como contexto imediato
# (e mantem no banco por cliente). Padrao: 30 (~15 trocas). O contexto anterior
# a essa janela e preservado no resumo .md de cada cliente.
HISTORICO_LIMIT=30

# Tempo de espera (ms) apos a ultima mensagem antes de responder. Agrupa
# mensagens enviadas em sequencia em uma unica resposta. Padrao: 5000 (5s).
DEBOUNCE_MS=5000

# Intervalo minimo (ms) entre avisos de midia (audio/imagem) para um mesmo
# numero, para nao repetir o alerta numa rajada de midias. Padrao: 60000 (60s).
MIDIA_COOLDOWN_MS=60000

# (Opcional) Endpoint de consulta de processos do escritorio.
# Se vazio, usa o padrao embutido no codigo.
DATAJUD_API_URL=https://ferreiraramos.adv.br/api/datajud_autocomplete.php

# (Opcional) Base da API do escritorio (clientes.php / processos.php) usada para
# localizar o processo do cliente por CPF ou nome. Se vazio, usa o padrao embutido.
CRM_API_URL=https://ferreiraramos.adv.br/api

# (Opcional) TTL (ms) do cache em memoria das listas de clientes/processos. Padrao: 60000.
CRM_CACHE_MS=60000

# (PENDENTE) Token da API do escritorio. Hoje a API esta aberta so por causa desta
# automacao; vai VOLTAR a exigir token. Quando isso ocorrer, preencher aqui e ligar
# o envio do cabecalho no crm.js (ver TODO(token) no getJson). Formato a confirmar.
# O DataJud NAO usa token (e API publica).
#CRM_API_TOKEN=
