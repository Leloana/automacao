# Este .gitignore cobre a RAIZ do projeto. O de dentro de "sistema/" so vale de
# la para baixo — por isso segredos e logs deixados aqui na raiz ficavam
# desprotegidos e podiam ir para o repositorio sem querer.

# Segredos (PRIVACIDADE/LGPD) - nunca vao para o repositorio
chaves.txt
*.env

# Senha da sincronizacao entre os PCs. O sync.php e versionado (nao tem segredo
# dentro), mas este arquivo TEM a senha e fica so na maquina / no servidor.
servidor/sync_config.php

# Logs gerados em runtime (contem dados de cliente)
log.txt
log-anterior.txt
